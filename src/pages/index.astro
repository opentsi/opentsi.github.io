---
// src/pages/index.astro
import { Button } from "@/components/ui/button";
import "@/styles/global.css"; // Adjust this to your global CSS path configured by shadcn
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Opentsi Initiative</title>
  </head>
  <body class="min-h-screen bg-white font-sans antialiased flex items-center">
    <main class="container mx-auto px-6 py-24 md:py-32 lg:px-12 max-w-7xl">
      {
        /* We constrain the width of the text to roughly half the screen to match the design */
      }
      <div class="max-w-2xl flex flex-col items-start gap-6">
        <h1
          class="text-[3.5rem] sm:text-6xl font-bold tracking-tight text-black leading-[1.05]"
        >
          Connect With More Than 2'300 R and Data Enthusiasts!
        </h1>

        <p class="text-xl text-gray-600 leading-relaxed mt-2 pr-4">
          Founded in 2014, the Zurich R User group is one of the largest R user
          groups in Europe. Join our meetup events and become part of a lively
          analytics community. Thanks to our speakers, hosts, and sponsors, our
          events are completely free.
        </p>

        <Button
          client:load
          class="mt-4 px-8 py-7 text-base font-medium bg-black text-white hover:bg-zinc-800 rounded-md"
        >
          Attend a Meetup
        </Button>
      </div>
    </main>
  </body>
</html>
